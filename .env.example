# Copy to `.env.local` and fill in values (never commit `.env.local`).

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- ElevenLabs (TTS: Turkish + English) ---
ELEVENLABS_API_KEY=

# Recommended: one voice ID per language (from ElevenLabs Voices UI).
ELEVENLABS_VOICE_ID_TR=
ELEVENLABS_VOICE_ID_EN=

# Fallback if a language-specific voice is not set.
# ELEVENLABS_VOICE_ID=

# Default model (multilingual works for both TR and EN).
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Optional: override model per language.
# ELEVENLABS_MODEL_ID_TR=
# ELEVENLABS_MODEL_ID_EN=

# Optional: mp3 quality preset.
# ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# Default language when POST body omits `language`: tr | en
ELEVENLABS_DEFAULT_LANGUAGE=tr

# Optional: self-hosted or enterprise base URL.
# ELEVENLABS_BASE_URL=https://api.elevenlabs.io

# --- Supabase (if used) ---
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
