# Copy to `.env.local` and fill in values (never commit `.env.local`).

# --- OpenAI (vision + JSON: /api/identify, /api/analyze) ---
OPENAI_API_KEY=
# Tek satırla ikisini birden (identify + analyze) aynı modele bağlamak için:
# OPENAI_MODEL=gpt-4o
# Veya endpoint başına (önerilen — identify ucuz, analyze güçlü varsayılan):
# OPENAI_MODEL_IDENTIFY=gpt-4o-mini
# OPENAI_MODEL_ANALYZE=gpt-4o

# --- ElevenLabs (TTS: Turkish + English) ---
ELEVENLABS_API_KEY=

# Recommended: one voice ID per language. Use a voice *you* created (e.g. Instant Voice Clone).
# Free ElevenLabs accounts cannot use library voices via the API — those return HTTP 402.
ELEVENLABS_VOICE_ID_TR=
ELEVENLABS_VOICE_ID_EN=

# Fallback if a language-specific voice is not set.
# ELEVENLABS_VOICE_ID=

# Default model (multilingual works for both TR and EN).
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Optional: override model per language.
# ELEVENLABS_MODEL_ID_TR=
# ELEVENLABS_MODEL_ID_EN=

# Optional: mp3 quality preset.
# ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# Default language when POST body omits `language`: tr | en
ELEVENLABS_DEFAULT_LANGUAGE=tr

# Optional: self-hosted or enterprise base URL.
# ELEVENLABS_BASE_URL=https://api.elevenlabs.io

# --- Supabase (if used) ---
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Google Cloud Storage (render çıktısı) ---
GCS_BUCKET_NAME=your-bucket-name

# --- Remotion Cloud Run CLI (worker deploy için, proje kökünde .env — asla commit etme) ---
# Cloud Shell: https://www.remotion.dev/docs/cloudrun/generate-env
# REMOTION_GCP_PROJECT_ID=your-gcp-project-id
# REMOTION_GCP_CLIENT_EMAIL=xxxxx@....iam.gserviceaccount.com
# REMOTION_GCP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- Remotion Cloud Run (opsiyonel — dağıtık render) ---
# npx remotion cloudrun services deploy sonrası worker URL
# REMOTION_CLOUDRUN_SERVICE_URL=https://YOUR-REMOTION-WORKER-xxxxx-ew.a.run.app
# Bundle’ı serve eden bu Next/Cloud Run servisinin kök URL’i
# CLOUD_RUN_SERVICE_URL=https://YOUR-NEXT-SERVICE-xxxxx-ew.a.run.app

# --- Render hızı (opsiyonel; OOM olursa concurrency düşür) ---
# Tüm /api/render isteklerini turbo moduna zorlar (scale 0.5, ultrafast, yüksek concurrency)
# RENDER_FORCE_TURBO=1
# RENDER_CONCURRENCY=4
# RENDER_SCALE=0.67
# RENDER_X264_PRESET=veryfast
# RENDER_JPEG_QUALITY=72
# RENDER_OFFTHREAD_VIDEO_THREADS=4
